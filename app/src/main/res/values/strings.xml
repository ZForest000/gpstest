    <!-- Help -->
    <string name="help_title">帮助</string>
    <string name="help_ttff_title">TTFF 首次定位时间</string>
    <string name="help_ttff_content">TTFF (Time To First Fix) 是指GPS接收器从启动到获得首次有效定位所需的时间。它反映了GPS信号的获取速度和接收器的性能。</string>
    <string name="help_ttff_excellent">优秀</string>
    <string name="help_ttff_good">良好</string>
    <string name="help_ttff_fair">一般</string>
    <string name="help_ttff_poor">较慢</string>
    <string name="help_location_title">位置信息</string>
    <string name="help_location_content">显示当前GPS定位获得的地理位置信息。</string>
    <string name="help_latitude_title">纬度</string>
    <string name="help_latitude_desc">地球表面位置的南北坐标，范围 -90° 到 +90°，正值表示北纬，负值表示南纬。</string>
    <string name="help_longitude_title">经度</string>
    <string name="help_longitude_desc">地球表面位置的东西坐标，范围 -180° 到 +180°，正值表示东经，负值表示西经。</string>
    <string name="help_altitude_title">海拔</string>
    <string name="help_altitude_desc">相对于平均海平面的高度，单位为米。</string>
    <string name="help_accuracy_title">精度</string>
    <string name="help_accuracy_desc">定位的估计精度半径，数值越小表示定位越精确。</string>
    <string name="help_speed_title">速度</string>
    <string name="help_speed_desc">设备的移动速度，单位为 km/h。</string>
    <string name="help_bearing_title">方位</string>
    <string name="help_bearing_desc">移动方向的方位角，范围 0° 到 360°，正北为 0°。</string>
    <string name="help_constellation_title">卫星星座</string>
    <string name="help_constellation_content">不同的全球导航卫星系统 (GNSS)。</string>
    <string name="help_constellation_gps">美国全球定位系统，覆盖全球，是最早的GNSS系统。</string>
    <string name="help_constellation_glonass">俄罗斯全球导航卫星系统，覆盖全球。</string>
    <string name="help_constellation_galileo">欧盟全球导航卫星系统，提供高精度定位服务。</string>
    <string name="help_constellation_beidou_name">北斗</string>
    <string name="help_constellation_beidou">中国北斗卫星导航系统，覆盖亚太及全球。</string>
    <string name="help_constellation_qzss">日本准天顶卫星系统，增强亚太地区定位精度。</string>
    <string name="help_dop_title">DOP 精度因子</string>
    <string name="help_dop_content">DOP (Dilution of Precision) 表示卫星几何分布对定位精度的影响，数值越小越好。</string>
    <string name="help_dop_pdop">位置精度因子，综合反映三维定位精度。</string>
    <string name="help_dop_hdop">水平精度因子，反映水平方向定位精度。</string>
    <string name="help_dop_vdop">垂直精度因子，反映垂直方向定位精度。</string>
    <string name="help_dop_quality">DOP 值质量评估：</string>
    <string name="help_dop_excellent">优秀</string>
    <string name="help_dop_good">良好</string>
    <string name="help_dop_fair">一般</string>
    <string name="help_dop_poor">较差</string>
    <string name="help_satellite_title">卫星信号</string>
    <string name="help_satellite_content">显示接收到的卫星信号详细信息。</string>
    <string name="help_cn0_title">信噪比 (C/N0)</string>
    <string name="help_cn0_desc">载波噪声密度比，反映信号质量。数值越高表示信号越强。</string>
    <string name="help_cn0_excellent">优秀</string>
    <string name="help_cn0_good">良好</string>
    <string name="help_cn0_fair">一般</string>
    <string name="help_cn0_poor">较弱</string>
    <string name="help_elevation_title">仰角</string>
    <string name="help_elevation_desc">卫星相对于地平线的角度，范围 0° 到 90°。仰角越高，信号通常越好。</string>
    <string name="help_azimuth_title">方位角</string>
    <string name="help_azimuth_desc">卫星相对于正北的方向角，范围 0° 到 360°。</string>
    <string name="help_ephemeris_title">星历数据</string>
    <string name="help_ephemeris_desc">卫星的精确轨道参数，用于计算卫星位置。有效期约2-4小时。</string>
    <string name="help_almanac_title">历书数据</string>
    <string name="help_almanac_desc">所有卫星的粗略轨道信息，用于快速搜索卫星。有效期约数月。</string>
    <string name="help_clock_title">时钟信息</string>
    <string name="help_clock_content">显示GPS接收器的时钟状态。</string>
    <string name="help_clock_bias_title">时钟偏差</string>
    <string name="help_clock_bias_desc">接收器时钟与GPS时间的偏差，单位纳秒。</string>
    <string name="help_clock_drift_title">时钟漂移</string>
    <string name="help_clock_drift_desc">时钟偏差的变化率，单位纳秒/秒。</string>
    <string name="help_agps_title">A-GPS 辅助定位</string>
    <string name="help_agps_content">A-GPS (Assisted GPS) 通过网络下载辅助数据加速定位。</string>
    <string name="help_agps_ephemeris_title">星历注入</string>
    <string name="help_agps_ephemeris_desc">下载并注入当前卫星的精确轨道数据，可显著减少TTFF。</string>
    <string name="help_agps_almanac_title">历书注入</string>
    <string name="help_agps_almanac_desc">下载并注入卫星概略位置数据，帮助快速搜索卫星。</string>
    <string name="help_satellite_detail_title">卫星详情 (原始测量数据)</string>
    <string name="help_satellite_detail_content">点击卫星卡片可查看详细的原始测量数据，这些数据来自GNSS接收器的底层输出。</string>
    <string name="help_raw_measurement_title">原始测量数据</string>
    <string name="help_carrier_freq_title">载波频率</string>
    <string name="help_carrier_freq_desc">卫星信号的载波频率，不同星座使用不同频段。如GPS L1频段约为1575.42 MHz。</string>
    <string name="help_carrier_cycles_title">载波周期</string>
    <string name="help_carrier_cycles_desc">自信号锁定以来累计的载波周期数，用于高精度相位测量。</string>
    <string name="help_doppler_shift_title">多普勒频移</string>
    <string name="help_doppler_shift_desc">由于卫星与接收器相对运动产生的频率偏移，可用于计算卫星径向速度。</string>
    <string name="help_agc_title">AGC 自动增益控制</string>
    <string name="help_agc_desc">接收器的自动增益控制电平，反映信号放大程度。异常值可能表示干扰。</string>
    <string name="help_baseband_cn0_title">基带信噪比</string>
    <string name="help_baseband_cn0_desc">基带处理后的信噪比，与C/N0类似但经过数字信号处理。通常略低于射频端的C/N0。</string>
    <string name="help_multipath_title">多路径检测</string>
    <string name="help_multipath_desc">指示信号是否经过反射到达接收器。多路径效应会降低定位精度。</string>
</resources>
